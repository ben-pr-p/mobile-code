{
  "name": "@flockcode/server",
  "version": "0.0.1",
  "bin": {
    "flockcode": "./src/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ],
  "engines": {
    "bun": ">=1.2.17"
  },
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "bun src/server.ts",
    "test": "bun test",
    "build:diff-page": "bun build src/diff-page/index.html --outdir=src/diff-page/dist --minify"
  },
  "dependencies": {
    "@durable-streams/server": "0.2.1",
    "@fly/sprites": "^0.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@opencode-ai/sdk": "^1.2.10",
    "@pierre/diffs": "^1.0.11",
    "@tanstack/ai": "^0.5.1",
    "@tanstack/ai-gemini": "^0.5.0",
    "durable-streams-web-standard": "github:ben-pr-p/durable-streams-web-standard",
    "envalid": "^8.1.1",
    "hono": "4.12.5",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.2"
  }
}
